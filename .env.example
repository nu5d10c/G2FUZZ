# G2FUZZ LLM Configuration
# Copy this file to .env and fill in your values

# Required: Your LLM API key
LLM_API_KEY=your-api-key-here

# Optional: API base URL (defaults to OpenAI's endpoint if not set)
# For OpenAI-compatible services, specify the base URL:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://your-custom-endpoint/v1

# Optional: Model name (defaults to gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini
