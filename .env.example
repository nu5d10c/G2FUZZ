# G2FUZZ LLM Configuration
# Copy this file to .env and fill in your values
#
# Uses standard OpenAI environment variables recognized by the OpenAI SDK
# and OpenAI-compatible services (e.g., Azure, DeepSeek, local LLMs).

# Required: Your LLM API key
OPENAI_API_KEY=your-api-key-here

# Optional: API base URL (defaults to https://api.openai.com/v1 if not set)
# For OpenAI-compatible services, specify the base URL:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-custom-endpoint/v1

# Optional: Model name (defaults to gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini
